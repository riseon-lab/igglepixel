  "models": [
    {
      "id": "wan22-i2v",
      "name": "Wan 2.2 — Image to Video",
      "category": "video",
      "description": "Alibaba's Wan 2.2 image-to-video. Animates a still into ~3.4 s of motion at 480p or 720p. 14B variant for high-VRAM cards (best motion fidelity), 5B for consumer GPUs.",
      "runner_module": "backend.runners.wan22_i2v",
      "hf_repo": "Wan-AI/Wan2.2-TI2V-5B-Diffusers",
      "license": {
        "type": "commercial",
        "label": "Apache 2.0",
        "url": "https://www.apache.org/licenses/LICENSE-2.0"
      },
      "min_vram_gb": 8,
      "recommended_vram_gb": 24,
      "supports_lora": true,
      "gpu_support": ["nvidia"],
      "dual_expert": true,
      "variants": [
        {
          "id": "14b",
          "label": "14B — workhorse",
          "description": "Best motion fidelity. ~80 GB at BF16; needs INT8 for Blackwell-class workstations and below.",
          "hf_repo": "Wan-AI/Wan2.2-I2V-A14B-Diffusers",
          "auto_min_vram_gb": 48,
          "quants": [
            { "id": "bf16", "label": "BF16", "description": "Best quality",     "vram_gb": 80, "auto_min_vram_gb": 80 },
            { "id": "int8", "label": "INT8", "description": "Faster, near-bf16","vram_gb": 40, "auto_min_vram_gb": 48 },
            { "id": "nf4",  "label": "NF4",  "description": "Smallest 14B",     "vram_gb": 22, "auto_min_vram_gb": 0  }
          ]
        },
        {
          "id": "5b",
          "label": "5B — consumer",
          "description": "TI2V-5B unified model. Fast and fits modern consumer GPUs.",
          "hf_repo": "Wan-AI/Wan2.2-TI2V-5B-Diffusers",
          "auto_min_vram_gb": 0,
          "quants": [
            { "id": "bf16", "label": "BF16", "description": "Best quality",     "vram_gb": 27, "auto_min_vram_gb": 36 },
            { "id": "int8", "label": "INT8", "description": "Faster, near-bf16","vram_gb": 14, "auto_min_vram_gb": 16 },
            { "id": "nf4",  "label": "NF4",  "description": "Fits 12 GB cards", "vram_gb": 8,  "auto_min_vram_gb": 0  }
          ]
        }
      ],
      "default_size_by_vram": [
        { "min_gb": 80, "w": 1280, "h": 720 },
        { "min_gb": 36, "w": 832,  "h": 480 },
        { "min_gb": 0,  "w": 640,  "h": 384 }
      ],
      "param_groups": ["prompt", "generation", "dimensions", "video"],
      "param_keys":   ["prompt", "negative_prompt", "seed", "steps", "cfg", "cfg_low", "width", "height", "num_frames", "fps"],
      "param_overrides": {
        "steps":      { "default": 30 },
        "cfg":        { "default": 5.0, "min": 0, "max": 10, "step": 0.1, "label": "Guidance (high-noise)" },
        "cfg_low":    { "default": 5.0, "min": 0, "max": 10, "step": 0.1, "label": "Guidance (low-noise)" },
        "width":      { "default": 832,  "step": 16, "min": 256, "max": 1280 },
        "height":     { "default": 480,  "step": 16, "min": 256, "max": 720 },
        "num_frames": { "default": 81,   "step": 1,  "min": 16,  "max": 121 },
        "fps":        { "default": 24,   "step": 1,  "min": 8,   "max": 30 }
      },
      "aspect_presets": [
        { "label": "16:9 480p",  "w": 832,  "h": 480 },
        { "label": "16:9 720p",  "w": 1280, "h": 720 },
        { "label": "Square",     "w": 624,  "h": 624 },
        { "label": "9:16 480p",  "w": 480,  "h": 832 }
      ],
      "image_inputs": [
        { "key": "ref", "label": "Source frame", "required": true, "hint": "First frame of the video" }
      ],
      "default_loras": [
        {
          "id": "wan22-i2v-lightning-4step",
          "label": "Lightning · 4 steps (I2V)",
          "description": "lightx2v's 4-step distillation. Drop steps from 30→4. Requires the 14B variant.",
          "usage_hint": "Set Steps to 4 and Guidance to 1.0",
          "hf_repo": "lightx2v/Wan2.2-Lightning",
          "files": [
            { "filename": "Wan2.2-I2V-A14B-4steps-lora-rank64-Seko-V1/high_noise_model.safetensors", "target": "high" },
            { "filename": "Wan2.2-I2V-A14B-4steps-lora-rank64-Seko-V1/low_noise_model.safetensors",  "target": "low"  }
          ],
          "applies_to": ["14b"],
          "strength_high": 1.0, "strength_low": 1.0,
          "default_on": false
        }
      ]
    },
    {
      "id": "tinyllama-chat",
      "name": "TinyLlama Chat 1.1B",
      "category": "llm",
      "description": "Lightweight local chat model for prototyping the text workspace UI. Small enough for quick iteration; not intended as the final quality bar.",
      "runner_module": "backend.runners.tinyllama_chat",
      "hf_repo": "TinyLlama/TinyLlama-1.1B-Chat-v1.0",
      "license": {
        "type": "commercial",
        "label": "Apache 2.0",
        "url": "https://www.apache.org/licenses/LICENSE-2.0"
      },
      "min_vram_gb": 4,
      "recommended_vram_gb": 8,
      "context_window": 2048,
      "context_by_vram": [
        { "min_gb": 12, "tokens": 4096, "label": "extended" },
        { "min_gb": 0,  "tokens": 2048, "label": "safe default" }
      ],
      "context_policy": {
        "mode": "workspace",
        "auto_compact_at": 0.82,
        "keep_recent_messages": 8
      },
      "supports_lora": false,
      "gpu_support": ["nvidia"],
      "quants": [
        { "id": "bf16", "label": "BF16", "description": "Best quality",      "vram_gb": 4, "auto_min_vram_gb": 8 },
        { "id": "int8", "label": "INT8", "description": "Lower memory",      "vram_gb": 3, "auto_min_vram_gb": 4 },
        { "id": "nf4",  "label": "NF4",  "description": "Smallest footprint","vram_gb": 2, "auto_min_vram_gb": 0 }
      ],
      "param_groups": ["llm"],
      "param_keys": ["thinking", "max_new_tokens", "temperature", "top_p"],
      "param_overrides": {
        "max_new_tokens": { "default": 512, "min": 64, "max": 2048, "step": 64 },
        "temperature":    { "default": 0.7, "min": 0, "max": 2, "step": 0.05 },
        "top_p":          { "default": 0.9, "min": 0, "max": 1, "step": 0.01 },
        "thinking":       { "default": true }
      }
    },
