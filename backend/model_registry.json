{
  "_comment": "Each entry declares a Python runner_module under backend/runners/. The runner owns weight loading + inference. backend/runner_host.py wraps it behind a localhost FastAPI; backend/launcher.py spawns it.",
  "upscalers": [
    {
      "id": "realesrgan-x4-plus",
      "label": "Real-ESRGAN ×4 (general)",
      "description": "Classic all-purpose upscaler. Strong on photoreal and illustration.",
      "scale": 4,
      "hf_repo": "ai-forever/Real-ESRGAN",
      "weight_file": "RealESRGAN_x4plus.pth",
      "compatible_with": ["image"]
    },
    {
      "id": "realesrgan-x4-anime",
      "label": "Real-ESRGAN ×4 (anime)",
      "description": "Tuned for anime/illustration. Cleaner line edges than the general model.",
      "scale": 4,
      "hf_repo": "ai-forever/Real-ESRGAN",
      "weight_file": "RealESRGAN_x4plus_anime_6B.pth",
      "compatible_with": ["image"]
    },
    {
      "id": "remacri-x4",
      "label": "4× Remacri (photoreal)",
      "description": "Community favourite for photographic upscales. Slightly softer than UltraSharp.",
      "scale": 4,
      "hf_repo": "FacehugmanIII/4x_foolhardy_Remacri",
      "weight_file": "4x_foolhardy_Remacri.pth",
      "compatible_with": ["image"]
    },
    {
      "id": "ultrasharp-x4",
      "label": "4× UltraSharp",
      "description": "Sharp detail recovery. Great on faces and textures; can over-sharpen.",
      "scale": 4,
      "hf_repo": "Kim2091/UltraSharp",
      "weight_file": "4x-UltraSharp.pth",
      "compatible_with": ["image"]
    }
  ],
  "models": [
    {
      "id": "flux-dev",
      "name": "FLUX.1-dev",
      "category": "image",
      "description": "Black Forest Labs' open-weight rectified-flow transformer. Excellent photorealism, hands, faces, and text-in-image. Native 1024×1024. Gated repo — accept the licence on HuggingFace and set HF_TOKEN.",
      "runner_module": "backend.runners.flux_dev",
      "hf_repo": "black-forest-labs/FLUX.1-dev",
      "license": {
        "type": "non-commercial",
        "label": "Non-commercial",
        "url": "https://huggingface.co/black-forest-labs/FLUX.1-dev/blob/main/LICENSE.md"
      },
      "min_vram_gb": 8,
      "recommended_vram_gb": 24,
      "supports_lora": true,
      "gpu_support": ["nvidia"],
      "default_size_by_vram": [
        { "min_gb": 80, "w": 1408, "h": 1408 },
        { "min_gb": 24, "w": 1024, "h": 1024 },
        { "min_gb": 0,  "w": 768,  "h": 768  }
      ],
      "quants": [
        { "id": "bf16", "label": "BF16", "description": "Best quality",        "vram_gb": 24, "auto_min_vram_gb": 36 },
        { "id": "int8", "label": "INT8", "description": "Faster, near-bf16",   "vram_gb": 12, "auto_min_vram_gb": 16 },
        { "id": "nf4",  "label": "NF4",  "description": "Fits 8 GB cards",     "vram_gb": 7,  "auto_min_vram_gb": 0  }
      ],
      "param_groups": ["prompt", "generation", "dimensions"],
      "param_keys":   ["prompt", "seed", "steps", "cfg", "width", "height"],
      "param_overrides": {
        "steps":  { "default": 28 },
        "cfg":    { "default": 3.5, "min": 0, "max": 10, "step": 0.1, "label": "Guidance" },
        "width":  { "default": 1024, "step": 16, "min": 256, "max": 2048 },
        "height": { "default": 1024, "step": 16, "min": 256, "max": 2048 }
      },
      "aspect_presets": [
        { "label": "Square",          "w": 1024, "h": 1024 },
        { "label": "Landscape 16:9",  "w": 1664, "h": 928  },
        { "label": "Portrait 9:16",   "w": 928,  "h": 1664 },
        { "label": "3:4",             "w": 1152, "h": 1536 },
        { "label": "4:3",             "w": 1536, "h": 1152 }
      ],
      "default_loras": []
    },
